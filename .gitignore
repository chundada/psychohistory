# 心理史学 Psychohistory - .gitignore

# 音频文件（大，不纳入版本控制）
*.wav
*.mp3
*.m4a
*.webm
*.flac
*.aac
*.ogg

# 字幕文件保留在版本控制中（它们是纯文本，是我们工作的基础素材）
# 不排除 *.vtt *.srt *.sbv *.ttml

# 临时文件
*~
*.swp
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.sublime-*

# Python缓存
__pycache__/
*.pyc

# Obsidian 个人工作区配置（库配置保留，工作区状态排除）
.obsidian/workspace*.json
.obsidian/graph.json

# Cursor / Trae AI 工具配置
.cursorrules
.cursor/
.claude/

# 本地临时/缓存文件
*.canvas
.trae-html-share-packages/

# 中间数据文件
intermediate_data.json
extraction_summary.json
