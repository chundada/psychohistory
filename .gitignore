# 心理史学 Psychohistory - .gitignore

# 音频文件（大，不纳入版本控制）
*.wav
*.mp3
*.m4a
*.webm
*.flac
*.aac
*.ogg

# 字幕文件保留在版本控制中（它们是纯文本，是我们工作的基础素材）
# 不排除 *.vtt *.srt *.sbv *.ttml

# 临时文件
*~
*.swp
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.sublime-*

# Python缓存
__pycache__/
*.pyc

# Obsidian 个人配置（整个目录不纳入版本控制）
.obsidian/

# Cursor / Trae AI 工具配置
.cursorrules
.cursor/
.claude/

# 本地临时/缓存文件
*.canvas
.trae-html-share-packages/

# 中间数据文件
intermediate_data.json
extraction_summary.json

# 灵感笔记字幕原件（大文件，本地保留，不纳入版本控制）
INSPIRATION-*.vtt

# 上传暂存目录
.uploads/

# 案例页共享静态资源（字体/第三方库，本地保留）
cases/_shared/
